{
  "name": "project_jamaica",
  "version": "1.0.0",
  "description": "Jamaica Parish Explorer",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:status": "cd server && node status-board.js",
    "dev:admin": "cd server && node admin.js",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && node --watch index.js",
    "build": "cd client && npm run build",
    "start": "cd server && NODE_ENV=production node index.js",
    "db:init": "cd server && node db/init.js",
    "fetch:places": "cd server && node db/fetch-places.js",
    "enrich:places": "cd server && node db/enrich-places.js",
    "seed:airports": "cd server && node db/seed-airports.js",
    "init": "cd server && node scripts/init-dev.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
