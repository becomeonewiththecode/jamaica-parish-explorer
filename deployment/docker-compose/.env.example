NODE_ENV=production
# Express server port inside the container; usually leave as 3001 to match the app default
PORT=3001
# Host port you want exposed externally (e.g. 80 or 3001)
HOST_PORT=80

# -----------------------------------------------------------------------------
# PostgreSQL — use either a full URL or discrete variables (not both needed)
# -----------------------------------------------------------------------------
# Option A — single connection string (overrides POSTGRES_* when set in server/.env):
# DATABASE_URL=postgresql://jamaica:jamaica@127.0.0.1:5432/jamaica
#
# Option B — variables only (DATABASE_URL unset). The API builds:
#   postgresql://POSTGRES_USER:POSTGRES_PASSWORD@POSTGRES_HOST:POSTGRES_PORT/POSTGRES_DB
# Passwords with special characters are safest here (URL-encoded automatically in code).
POSTGRES_USER=jamaica
POSTGRES_PASSWORD=jamaica
# Local Node on your machine:
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=jamaica
#
# Docker Compose overrides POSTGRES_HOST to `postgres` for the app container only
# (see docker-compose-build.yml / docker-compose-prod.yml), so you can keep
# POSTGRES_HOST=127.0.0.1 in this file for local `cd server && node index.js` and
# still use Compose without editing the file.

# Docker Compose: bind mounts next to the compose file (auto-created):
#   ./data/postgres  → PostgreSQL
#   ./data/jamaica   → JSON flight/weather caches (JAMAICA_DATA_DIR=/data)
# Do not mount over /app/server — it shadows the image node_modules.

# Status board and admin dashboard ports
STATUS_PORT=5555
ADMIN_PORT=5556

# Optional: Thunderforest API key for map base layers (frontend, via Vite)
# This will be baked into the built client when you run `npm run build` before building the image.
# VITE_THUNDERFOREST_API_KEY=your_thunderforest_api_key

# Flight and vessel data API keys (backend)
# RAPIDAPI_KEY=your_rapidapi_key
# OPENSKY_CLIENT_ID=your_opensky_client_id
# OPENSKY_CLIENT_SECRET=your_opensky_client_secret
# AISSTREAM_API_KEY=your_aisstream_api_key

# Weather API keys (backend)
# WEATHERAPI_KEY=your_weatherapi_key
# OPENWEATHER_API_KEY=your_openweather_api_key

# Admin dashboard authentication (required for admin site on port 5556)
# ADMIN_USER=admin
# ADMIN_PASSWORD=your_strong_random_password
# ADMIN_RESTART_TOKEN=your_restart_token
# Optional: max SQL backup upload size for admin restore (bytes, default 536870912)
# ADMIN_DB_RESTORE_MAX_BYTES=536870912
